# Application
PROJECT_NAME=DeployHub API
VERSION=1.0.0

# Security
SECRET_KEY=change-me-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite local par defaut)
DATABASE_URL=sqlite:///./deployhub.db

# CORS (separe par des virgules)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Deploiement
DEPLOY_HOST=localhost
DEPLOY_PORT_RANGE_START=8090
DEPLOY_PORT_RANGE_END=9000

# Email (skip pour l'instant : tokens logges en console)
EMAIL_ENABLED=false
FRONTEND_URL=http://localhost:5173